# Public, non-secret runtime config (EXPO_PUBLIC_ prefix = build-injected, fetched at runtime).
# Copy to .env and set per-environment. The real .env is git-ignored and never committed.

# Server feature-gate endpoint. Casino + custodial mode read their on/off flags from here,
# so a Play-safe stripped build can be toggled without a rebuild. Fails CLOSED if unreachable.
EXPO_PUBLIC_FEATURE_GATE_URL=https://gate.21pay.org/v1/flags
